{
  "name": "propfocus-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade Playwright + TypeScript E2E automation framework for PropFocus",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "smoke": "playwright test --grep @smoke",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.10.1",
    "dotenv": "^16.4.7",
    "typescript": "^5.7.2"
  }
}
