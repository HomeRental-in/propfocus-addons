    {
      "parameters": {
        "jsCode": "const lead = $input.first().json;\nconst now = new Date().toISOString();\nconst currentStep = parseInt(lead.step ?? lead.current_step ?? 0);\nlet newStep = currentStep + 1;\nlet newStatus = newStep > 5 ? 'ended' : 'active';\nif (newStep > 5) newStep = 5;\nreturn [{ json: { ...lead, current_step: newStep, last_action_at: now, status: newStatus } }];"
      },
      "id": "increment-step",
      "name": "Increment Step",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 400]
    },
