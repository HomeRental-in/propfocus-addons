      "id": "cron-trigger",
      "name": "Every Hour (9am-6pm Weekdays)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "operation": "readAllRows",
        "documentId": { "value": "YOUR_GOOGLE_SHEET_ID" },
        "sheetName": { "value": "Leads" },
        "filters": {
          "conditions": [{ "keyName": "status", "condition": "eq", "keyValue": "active" }]
        }
      },
      "id": "read-sheet",
      "name": "Read Active Leads",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.2,
      "position": [460, 300],
      "credentials": { "googleSheetsOAuth2Api": { "name": "Google Sheets" } }
    },
    {
      "parameters": {
        "jsCode": "const leads = $input.all();\nconst now = new Date();\nconst filtered = [];\n\nconst delays = { 0: 0, 1: 3, 2: 48, 3: 48, 4: 168, 5: 24 };\n\nfor (const item of leads) {\n  const lead = item.json;\n  const step = parseInt(lead.current_step || '0');\n  const lastAction = lead.last_action_at ? new Date(lead.last_action_at) : null;\n  if (lead.status !== 'active') continue;\n  const requiredHours = delays[step] || 0;\n  const hoursElapsed = lastAction ? (now - lastAction) / 3600000 : 999;\n  if (hoursElapsed >= requiredHours) {\n    filtered.push({ json: { ...lead, step, hoursElapsed: Math.round(hoursElapsed) } });\n  }\n}\n\nreturn filtered;"
      },
      "id": "check-delays",
      "name": "Filter Leads Due for Action",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            { "conditions": { "conditions": [{ "leftValue": "={{ $json.step }}", "rightValue": 0, "operator": { "type": "number", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "step0_view" },
            { "conditions": { "conditions": [{ "leftValue": "={{ $json.step }}", "rightValue": 1, "operator": { "type": "number", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "step1_check_connection" },
            { "conditions": { "conditions": [{ "leftValue": "={{ $json.step }}", "rightValue": 2, "operator": { "type": "number", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "step2_msg1" },
            { "conditions": { "conditions": [{ "leftValue": "={{ $json.step }}", "rightValue": 3, "operator": { "type": "number", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "step3_msg2" },
            { "conditions": { "conditions": [{ "leftValue": "={{ $json.step }}", "rightValue": 4, "operator": { "type": "number", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "step4_msg3" },
            { "conditions": { "conditions": [{ "leftValue": "={{ $json.step }}", "rightValue": 5, "operator": { "type": "number", "operation": "equals" } }] }, "renameOutput": true, "outputKey": "step5_msg4" }
          ]
        }
      },
