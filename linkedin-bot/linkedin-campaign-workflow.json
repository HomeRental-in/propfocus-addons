    {
      "parameters": {
        "jsCode": "// Generate all 5 messages + connect note for a new lead via Claude API\nconst lead = $input.first().json;\n\nconst response = await fetch('https://api.anthropic.com/v1/messages', {\n  method: 'POST',\n  headers: {\n    'Content-Type': 'application/json',\n    'x-api-key': $env.ANTHROPIC_API_KEY,\n    'anthropic-version': '2023-06-01'\n  },\n  body: JSON.stringify({\n    model: 'claude-sonnet-4-20250514',\n    max_tokens: 2000,\n    system: `You write LinkedIn outreach messages for JournalTrade (journaltrade.in) — a WhatsApp-based F&O trade journal for Indian retail traders. Traders log trades in natural language, get AI behavioral insights and EOD summaries. Free tier + Rs 299/month Pro.\n\nRules:\n- Peer-to-peer tone, never salesy\n- Reference their specific background\n- Each message under 300 characters\n- msg_1: soft intro after connecting\n- msg_2: specific F&O pain point (emotional trading, no review habit, random position sizing)\n- msg_3: social proof — other traders using it, no pressure\n- msg_4: direct ask — try free tier, 2 mins to set up\n- msg_5: final breakup message, leave door open\n- connect_note: warm note for connection request (max 200 chars)\n\nRespond ONLY with valid JSON, no markdown:\n{\n  \"connect_note\": \"...\",\n  \"msg_1\": \"...\",\n  \"msg_2\": \"...\",\n  \"msg_3\": \"...\",\n  \"msg_4\": \"...\",\n  \"msg_5\": \"...\"\n}`,\n    messages: [{\n      role: 'user',\n      content: `Generate outreach sequence for:\\nName: ${lead.name}\\nHeadline: ${lead.headline}\\nCompany: ${lead.company || 'N/A'}`\n    }]\n  })\n});\n\nconst data = await response.json();\nconst text = data.content[0].text.replace(/```json|```/g, '').trim();\nconst messages = JSON.parse(text);\n\nreturn [{ json: { ...lead, ...messages, current_step: 0, status: 'active', last_action_at: '' } }];"
      },
      "id": "generate-messages",
      "name": "Generate Messages with Claude",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 600]
    },
